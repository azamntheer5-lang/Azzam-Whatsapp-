<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/settingsToolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/primary"
        app:titleTextColor="#FFFFFF"
        app:navigationIcon="?attr/homeAsUpIndicator" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/settings_active_engine_label"
                android:textStyle="bold"
                android:textColor="@color/text_primary" />

            <Spinner
                android:id="@+id/spinnerEngine"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="24dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Claude API Keys" 
                android:textStyle="bold"
                android:textColor="@color/text_primary" />
            <EditText
                android:id="@+id/editClaudeKeys"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minLines="2"
                android:gravity="top"
                android:hint="@string/settings_multi_key_hint"
                android:inputType="textMultiLine" />
            <TextView
                android:id="@+id/linkClaudeKey"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="16dp"
                android:padding="4dp"
                android:text="@string/settings_get_claude_key"
                android:textColor="@color/primary"
                android:textSize="12sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Google Gemini API Keys"
                android:textStyle="bold"
                android:textColor="@color/text_primary" />
            <EditText
                android:id="@+id/editGeminiKeys"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minLines="2"
                android:gravity="top"
                android:hint="@string/settings_multi_key_hint"
                android:inputType="textMultiLine" />
            <TextView
                android:id="@+id/linkGeminiKey"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="16dp"
                android:padding="4dp"
                android:text="@string/settings_get_gemini_key"
                android:textColor="@color/primary"
                android:textSize="12sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Groq API Keys"
                android:textStyle="bold"
                android:textColor="@color/text_primary" />
            <EditText
                android:id="@+id/editGroqKeys"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minLines="2"
                android:gravity="top"
                android:hint="@string/settings_multi_key_hint"
                android:inputType="textMultiLine" />
            <TextView
                android:id="@+id/linkGroqKey"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="16dp"
                android:padding="4dp"
                android:text="@string/settings_get_groq_key"
                android:textColor="@color/primary"
                android:textSize="12sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hugging Face API Keys"
                android:textStyle="bold"
                android:textColor="@color/text_primary" />
            <EditText
                android:id="@+id/editHuggingFaceKeys"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minLines="2"
                android:gravity="top"
                android:hint="@string/settings_multi_key_hint"
                android:inputType="textMultiLine" />
            <TextView
                android:id="@+id/linkHuggingFaceKey"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="24dp"
                android:padding="4dp"
                android:text="@string/settings_get_huggingface_key"
                android:textColor="@color/primary"
                android:textSize="12sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonSaveSettings"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/save" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/settings_note"
                android:textSize="12sp"
                android:textColor="@color/text_secondary" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/settings_rotation_note"
                android:textSize="12sp"
                android:textColor="@color/text_secondary" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonClearHistory"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="@string/settings_clear_history"
                app:strokeColor="@color/primary"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/settings_clear_history_note"
                android:textSize="12sp"
                android:textColor="@color/text_secondary" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>
